# Comcof Shop environment. Copy to .env.local for development.
# LAUNCH mode: leave Supabase values empty; the shop renders honest launch
# states with no fake commerce. COMMERCE mode: set all Supabase values.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never exposed to the client. Used by server actions.
SUPABASE_SERVICE_ROLE_KEY=

# Feature flags: "on" to enable.
NEXT_PUBLIC_FLAG_CHECKOUT=
NEXT_PUBLIC_FLAG_SUBSCRIPTIONS=
NEXT_PUBLIC_FLAG_REVIEWS=
NEXT_PUBLIC_FLAG_LOYALTY=
NEXT_PUBLIC_FLAG_PARTNER_PRODUCTS=

# Administratively configured contact details.
NEXT_PUBLIC_SHOP_EMAIL=info@comcofgroup.com
# WhatsApp number in international format without plus, e.g. 2567XXXXXXXX
NEXT_PUBLIC_SHOP_WHATSAPP=
