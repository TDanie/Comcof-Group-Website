{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/shop", "destination": "https://comcof-shop.vercel.app/shop" },
    { "source": "/shop/:path*", "destination": "https://comcof-shop.vercel.app/shop/:path*" },
    { "source": "/account", "destination": "https://comcof-shop.vercel.app/account" },
    { "source": "/account/:path*", "destination": "https://comcof-shop.vercel.app/account/:path*" },
    { "source": "/admin", "destination": "https://comcof-shop.vercel.app/admin" },
    { "source": "/admin/:path*", "destination": "https://comcof-shop.vercel.app/admin/:path*" },
    { "source": "/_next/:path*", "destination": "https://comcof-shop.vercel.app/_next/:path*" }
  ]
}
